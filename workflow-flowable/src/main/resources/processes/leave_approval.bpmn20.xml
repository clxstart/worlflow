<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:flowable="http://flowable.org/bpmn"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
                  targetNamespace="http://www.clx.com/workflow">

    <bpmn:process id="leave_approval" name="请假审批流程" isExecutable="true">

        <!-- 开始节点 -->
        <bpmn:startEvent id="start" name="发起申请"/>

        <!-- 部门经理审批 -->
        <bpmn:userTask id="dept_approve" name="部门经理审批"
                       flowable:candidateGroups="dept_manager">
            <bpmn:extensionElements>
                <flowable:taskListener event="create"
                    class="com.clx.workflow.flowable.listener.TaskCreateListener"/>
                <flowable:taskListener event="complete"
                    class="com.clx.workflow.flowable.listener.TaskCompleteListener"/>
            </bpmn:extensionElements>
        </bpmn:userTask>

        <!-- 条件判断：请假天数>3天需要人事审批 -->
        <bpmn:exclusiveGateway id="gateway" name="审批路由"/>

        <!-- 人事审批 -->
        <bpmn:userTask id="hr_approve" name="人事审批"
                       flowable:candidateGroups="hr_manager">
            <bpmn:extensionElements>
                <flowable:taskListener event="create"
                    class="com.clx.workflow.flowable.listener.TaskCreateListener"/>
                <flowable:taskListener event="complete"
                    class="com.clx.workflow.flowable.listener.TaskCompleteListener"/>
            </bpmn:extensionElements>
        </bpmn:userTask>

        <!-- 结束节点 -->
        <bpmn:endEvent id="end" name="流程结束"/>

        <!-- 连线 -->
        <bpmn:sequenceFlow id="flow1" sourceRef="start" targetRef="dept_approve"/>

        <bpmn:sequenceFlow id="flow2" sourceRef="dept_approve" targetRef="gateway"/>

        <bpmn:sequenceFlow id="flow3" name="请假>3天" sourceRef="gateway" targetRef="hr_approve">
            <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
                ${leaveDays > 3}
            </bpmn:conditionExpression>
        </bpmn:sequenceFlow>

        <bpmn:sequenceFlow id="flow4" name="请假<=3天" sourceRef="gateway" targetRef="end">
            <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
                ${leaveDays <= 3}
            </bpmn:conditionExpression>
        </bpmn:sequenceFlow>

        <bpmn:sequenceFlow id="flow5" sourceRef="hr_approve" targetRef="end"/>

    </bpmn:process>

    <!-- 流程图可视化信息 -->
    <bpmndi:BPMNDiagram id="BPMNDiagram_leave_approval">
        <bpmndi:BPMNPlane bpmnElement="leave_approval">
            <bpmndi:BPMNShape bpmnElement="start">
                <omgdc:Bounds x="100" y="200" width="36" height="36"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="dept_approve">
                <omgdc:Bounds x="200" y="175" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="gateway">
                <omgdc:Bounds x="350" y="200" width="50" height="50"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="hr_approve">
                <omgdc:Bounds x="450" y="275" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="end">
                <omgdc:Bounds x="600" y="200" width="36" height="36"/>
            </bpmndi:BPMNShape>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>

</bpmn:definitions>